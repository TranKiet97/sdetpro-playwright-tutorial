{
  "compilerOptions": {
    "types": ["node"],
    "target": "ESNext",
    "lib": ["dom", "ESNext", "ES6", "ES2022"],
    "strict": true,
    "resolveJsonModule": true,
    "pretty": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,
    "noEmit": true,
    "useUnknownInCatchVariables": false,
    "typeRoots": ["./node_modules/@types"],
    "checkJs": true,
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": ".dist",
    "sourceMap": true,
    "removeComments": true,
    "alwaysStrict": true,
    "strictNullChecks": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["ascend-vista/page-object/pages/*"],
      "@components/*": ["ascend-vista/page-object/components/*"],
      "@fixtures/*": ["ascend-vista/fixtures/*"],
      "@utils/*": ["ascend-vista/utils/*"],
      "@ascend-vista/*": ["ascend-vista/*"],
      "@helpers/*": ["lib/helpers/*"],
      "@data-preparation/*": ["ascend-vista/api/data-preparation/*"],
      "@api/*": ["ascend-vista/api/*"],
      "@api-request/*": ["ascend-vista/api/api-request/*"],
      "@constants/*": ["ascend-vista/constants/*"]
    }
  },
  "compileOnSave": true,
  "include": ["./**/*"],
  "exclude": ["node_modules", "playwright-report"]
}
